# Fetch URL Skill Environment Variables
# Copy this file to .env and set your actual bearer token (or use credgoo instead)

# Recommended: use credgoo to store your token
#   credgoo add FETCH_URL_BEARER
# Or reuse your web-search token:
#   credgoo add WEB_SEARCH_BEARER

# Fallback: set token directly here (not recommended — use credgoo)
# FETCH_URL_BEARER=your_bearer_token_here
