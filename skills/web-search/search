#!/usr/bin/env bash
# web-search launcher with auto-update support.
# Resolves symlinks, checks for updates (7-day cycle), then runs the Python script.
#
# Flags handled here (not passed to Python):
#   --update    Force an update now
#   --selfcheck Show version and last-update timestamp

# ── Resolve skill directory (follow symlinks) ──
SELF="${BASH_SOURCE[0]}"
while [ -L "$SELF" ]; do
    DIR="$(cd "$(dirname "$SELF")" && pwd)"
    SELF="$(readlink "$SELF")"
    [[ "$SELF" != /* ]] && SELF="$DIR/$SELF"
done
SKILL_DIR="$(cd "$(dirname "$SELF")" && pwd)"
STAMP_FILE="$SKILL_DIR/.last-update"
AUTO_UPDATE_DAYS=7

# ── Handle launcher-only flags ──
case "${1:-}" in
    --update)
        echo "Updating web-search..."
        cd "$SKILL_DIR"
        if [ -d ".git" ]; then
            git pull --ff-only 2>&1 || echo "Warning: git pull failed (maybe offline)"
        fi
        uv sync --quiet 2>&1
        date +%s > "$STAMP_FILE"
        echo "✓ Updated $(date)"
        exit 0
        ;;
    --selfcheck)
        source_py="$SKILL_DIR/scripts/search.py"
        version="?"
        if [ -f "$source_py" ]; then
            version=$(grep -o 'version.*"[^"]*"' "$SKILL_DIR/pyproject.toml" 2>/dev/null | head -1 | grep -o '[0-9][^"]*' || echo "?")
        fi
        last="never"
        if [ -f "$STAMP_FILE" ]; then
            last=$(date -r "$STAMP_FILE" "+%Y-%m-%d %H:%M" 2>/dev/null || cat "$STAMP_FILE")
        fi
        echo "web-search v${version}"
        echo "  dir:   $SKILL_DIR"
        echo "  last:  $last"
        exit 0
        ;;
esac

# ── Auto-update check (non-blocking) ──
if [ -d "$SKILL_DIR/.git" ]; then
    needs_update=false
    if [ ! -f "$STAMP_FILE" ]; then
        needs_update=true
    else
        last_ts=$(cat "$STAMP_FILE" 2>/dev/null || echo 0)
        now_ts=$(date +%s)
        # macOS date doesn't support %s in all contexts, but this works
        age_days=$(( (now_ts - last_ts) / 86400 ))
        if [ "$age_days" -ge "$AUTO_UPDATE_DAYS" ]; then
            needs_update=true
        fi
    fi

    if $needs_update; then
        # Update in background — don't block the search
        (
            cd "$SKILL_DIR"
            git pull --ff-only --quiet 2>/dev/null
            uv sync --quiet 2>/dev/null
            date +%s > "$STAMP_FILE"
        ) &>/dev/null &
    fi
fi

# ── Run the search ──
cd "$SKILL_DIR" && exec uv run scripts/search.py "$@"
