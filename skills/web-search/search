#!/usr/bin/env python3
"""
Web Search CLI - Wrapper for scripts/search.py
Can be run from anywhere - will automatically find and switch to skill directory.
"""
import sys
import os
from pathlib import Path

# Find the skill directory (where this script lives)
script_path = Path(__file__).resolve()
skill_dir = script_path.parent

# Change to skill directory so relative paths work correctly
os.chdir(skill_dir)

# Add scripts directory to path and run main
scripts_dir = skill_dir / "scripts"
sys.path.insert(0, str(scripts_dir))

from scripts.search import main

if __name__ == "__main__":
    main()