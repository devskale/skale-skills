vars: { d2-config: { layout-engine: elk } }
user: { shape: person }
system: "Skale Skills" {
  skills: "skills/ (CLI-driven)"
  extensions: "extensions/ (pi runtime)"
  skiller: "skiller CLI"
}
pi: "pi agent"
credgoo: { shape: cylinder; label: "credgoo" }
user -> pi: runs
pi -> system.skills: loads
pi -> system.extensions: loads
system.skills -> credgoo: keys
